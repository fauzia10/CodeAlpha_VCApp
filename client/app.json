{
  "expo": {
    "name": "Syncora",
    "slug": "syncora",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/syncora-icon-only.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FCE7EF",
        "foregroundImage": "./assets/syncora-icon-only.png"
      }
    },
    "web": {
      "favicon": "./public/syncora-favicon-v10.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
